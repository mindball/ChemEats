<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand d-flex align-items-center" href="">
            <img src="https://www.cpachem.com/_custom/_cpachem.com/images/logo-a.png" alt="CPAChem" style="height: 28px;" class="me-2" />
            @* <span>ChemEats</span> *@
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>
<div class="@NavMenuCssClass nav-scrollable">
    <nav class="nav flex-column">

        <!-- Always visible -->
        <div class="nav-item px-3">
            <NavLink class="nav-link d-flex align-items-center" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill me-2 d-inline-flex align-items-center"></span> Dashboard
            </NavLink>
        </div>

        <!-- All authenticated users: Browse Menus, Place Order, My Orders -->
        <AuthorizeView>
            <Authorized>

                <div class="nav-item px-3 nav-section-label">
                    <small class="text-uppercase">Lab Menu</small>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="menus/view">
                        <span class="bi bi-journal-text me-2 d-inline-flex align-items-center"></span> Browse Menus
                    </NavLink>
                </div>

                <div class="nav-item px-3 nav-section-label">
                    <small class="text-uppercase">Orders</small>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="menus/order">
                        <span class="bi bi-cart-fill me-2 d-inline-flex align-items-center"></span> Place Order
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="orders/my">
                        <span class="bi bi-receipt me-2 d-inline-flex align-items-center"></span> My Orders
                    </NavLink>
                </div>

                <div class="nav-item px-3 nav-section-label">
                    <small class="text-uppercase">Control Panel</small>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="account/change-password">
                        <span class="bi bi-key-fill me-2 d-inline-flex align-items-center"></span> Change Password
                    </NavLink>
                </div>

            </Authorized>
        </AuthorizeView>

        <!-- Supervisor and Admin: Create Menu, Suppliers -->
        <AuthorizeView Roles="Supervisor,Admin">
            <Authorized>

                <div class="nav-item px-3 nav-section-label">
                    <small class="text-uppercase">Management</small>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="upload-menu">
                        <span class="bi bi-clipboard-plus me-2 d-inline-flex align-items-center"></span> Create Menu
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="get-suppliers">
                        <span class="bi bi-building me-2 d-inline-flex align-items-center"></span> Suppliers
                    </NavLink>
                </div>

            </Authorized>
        </AuthorizeView>

        <!-- Admin only: Add Supplier, Control Panel, Payments -->
        <AuthorizeView Roles="Admin">
            <Authorized>

                <div class="nav-item px-3 nav-section-label">
                    <small class="text-uppercase">Administration</small>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="register-supplier">
                        <span class="bi bi-plus-circle-fill me-2 d-inline-flex align-items-center"></span> Add Supplier
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="admin">
                        <span class="bi bi-shield-lock-fill me-2 d-inline-flex align-items-center"></span> Control Panel
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link d-flex align-items-center" href="admin/payments">
                        <span class="bi bi-cash-coin me-2 d-inline-flex align-items-center"></span> Payments
                    </NavLink>
                </div>

            </Authorized>
        </AuthorizeView>

    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu() => collapseNavMenu = !collapseNavMenu;
}