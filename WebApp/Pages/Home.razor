@page "/"

@using WebApp.Services.Menus
@inject IMenuDataService MenuDataService

<PageTitle>CPAChem | ChemEats</PageTitle>

<div class="container-fluid">
    <div class="text-center mb-4 pt-3">
        <img src="https://www.cpachem.com/_custom/_cpachem.com/images/logo-a.png"
             alt="CPAChem"
             style="height: 52px;"
             class="mb-3" />
        <h2 style="color: #003d61; font-weight: 700;">ChemEats</h2>
        <p class="text-muted mb-0">Employee Meal Ordering System</p>
    </div>

    <AuthorizeView>
        <Authorized>
            <div class="row g-4 justify-content-center">
                <div class="col-md-4">
                    <a href="menus/order" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm" style="border-top: 3px solid #00629B !important;">
                            <div class="card-body text-center py-4">
                                <i class="bi bi-cart-fill fs-1" style="color: #00629B;"></i>
                                <h5 class="mt-3" style="color: #003d61;">Place Order</h5>
                                <p class="text-muted small mb-0">Browse active menus and order your meal</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="orders/my" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm" style="border-top: 3px solid #26b050 !important;">
                            <div class="card-body text-center py-4">
                                <i class="bi bi-receipt fs-1" style="color: #26b050;"></i>
                                <h5 class="mt-3" style="color: #003d61;">My Orders</h5>
                                <p class="text-muted small mb-0">View and track your order history</p>
                            </div>
                        </div>
                    </a>
                </div>
                <div class="col-md-4">
                    <a href="menus/view" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm" style="border-top: 3px solid #f0ad4e !important;">
                            <div class="card-body text-center py-4">
                                <i class="bi bi-journal-text fs-1" style="color: #f0ad4e;"></i>
                                <h5 class="mt-3" style="color: #003d61;">Browse Menus</h5>
                                <p class="text-muted small mb-0">Explore available and past menus</p>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="text-center py-5">
                <i class="bi bi-lock-fill fs-1 text-muted"></i>
                <p class="mt-3 text-muted">Please <a href="Account/Login" style="color: #00629B; font-weight: 600;">log in</a> to access the ordering system.</p>
            </div>

            @if (_isLoading)
            {
                <div class="alert alert-info">
                     <i class="bi bi-info-circle me-1"></i> Loading today's menus...
                </div>
            }
            else if (_activeMenus != null && _activeMenus.Any())
            {
                <div class="mt-5">
                    <h4 class="text-center mb-4" style="color: #003d61;">
                        <i class="bi bi-calendar-check me-2"></i>Today's Active Menus
                    </h4>
                    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                        @foreach (var menu in _activeMenus)
                        {
                            <div class="col">
                                <div class="card h-100 border-0 shadow-sm" style="border-top: 3px solid #f0ad4e !important;">
                                    <div class="card-header bg-white border-bottom-0 pt-3 pb-0">
                                        <h5 class="card-title mb-1" style="color: #003d61;">
                                            <i class="bi bi-shop me-2"></i>@menu.SupplierName
                                        </h5>
                                        <small class="text-muted fw-semibold">
                                            <i class="bi bi-clock me-1"></i>Active until: <span class="text-danger">@menu.ActiveUntil.ToString("HH:mm")</span>
                                        </small>
                                    </div>
                                    <div class="card-body">
                                        <hr class="mt-0 mb-3" />
                                        @if (menu.Meals.Any())
                                        {
                                            <div class="list-group list-group-flush" style="max-height: 350px; overflow-y: auto;">
                                                @foreach (var meal in menu.Meals)
                                                {
                                                    <div class="list-group-item d-flex justify-content-between align-items-center bg-transparent px-2 py-2">
                                                        <span class="text-break me-3">@meal.Name</span>
                                                        <span class="badge rounded-pill text-dark border shadow-sm" style="background-color: #f8f9fa; font-size: 0.9rem;">
                                                            @meal.Price.ToString("C")
                                                        </span>
                                                    </div>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="text-center text-muted my-4">
                                                <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                                <p class="mb-0">No meals available.</p>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </NotAuthorized>
    </AuthorizeView>
</div>

@code {
    private IEnumerable<MenuDto>? _activeMenus;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            IEnumerable<MenuDto> menus = await MenuDataService.GetActiveMenusAsync();
            _activeMenus = menus.Where(m => m.IsActive).ToList();
        }
        catch
        {
            // Ignore error for unauthenticated/anonymous guests
        }
        finally
        {
            _isLoading = false;
        }
    }
}
