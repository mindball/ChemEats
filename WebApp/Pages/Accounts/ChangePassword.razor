@page "/account/change-password"
@using System.ComponentModel.DataAnnotations
@using Shared.DTOs.Employees
@using WebApp.Services.Employees
@attribute [Microsoft.AspNetCore.Authorization.Authorize]

<PageTitle>Change Password</PageTitle>

<h3 class="mb-3" style="color: #003d61;">
    <i class="bi bi-key-fill me-2"></i>Change Password
</h3>

@if (RequirePasswordChange)
{
    <div class="alert alert-warning">
        Your current password is temporary. Please set a new password to continue.
    </div>
}

<EditForm Model="Model" OnValidSubmit="HandleSubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger" />

    <div class="mb-3">
        <label class="form-label">Current password</label>
        <InputText class="form-control" type="password" @bind-Value="Model.CurrentPassword" />
        <ValidationMessage For="() => Model.CurrentPassword" class="text-danger" />
    </div>

    <div class="mb-3">
        <label class="form-label">New password</label>
        <InputText class="form-control" type="password" @bind-Value="Model.NewPassword" />
        <ValidationMessage For="() => Model.NewPassword" class="text-danger" />
    </div>

    <div class="mb-3">
        <label class="form-label">Confirm new password</label>
        <InputText class="form-control" type="password" @bind-Value="Model.ConfirmPassword" />
        <ValidationMessage For="() => Model.ConfirmPassword" class="text-danger" />
    </div>

    <div class="d-flex gap-2">
        <button class="btn btn-primary" type="submit" disabled="@IsSaving">
            <i class="bi bi-save me-1"></i>Save
        </button>

        @if (!RequirePasswordChange)
        {
            <button class="btn btn-outline-secondary" type="button" @onclick="GoBack">
                Cancel
            </button>
        }
    </div>
</EditForm>

@if (!string.IsNullOrWhiteSpace(SuccessMessage))
{
    <div class="alert alert-success mt-3">@SuccessMessage</div>
}

@if (!string.IsNullOrWhiteSpace(ErrorMessage))
{
    <div class="alert alert-danger mt-3">@ErrorMessage</div>
}

@code {
    [Inject] private IEmployeeDataService EmployeeDataService { get; set; } = null!;
    [Inject] private NavigationManager NavigationManager { get; set; } = null!;

    [SupplyParameterFromQuery(Name = "required")]
    private bool RequirePasswordChange { get; set; }

    private ChangePasswordModel Model { get; set; } = new();
    private bool IsSaving { get; set; }
    private string? SuccessMessage { get; set; }
    private string? ErrorMessage { get; set; }

    private async Task HandleSubmitAsync()
    {
        ErrorMessage = null;
        SuccessMessage = null;
        IsSaving = true;

        try
        {
            ChangePasswordRequestDto request = new(
                Model.CurrentPassword,
                Model.NewPassword,
                Model.ConfirmPassword);

            bool changed = await EmployeeDataService.ChangeMyPasswordAsync(request);
            if (!changed)
            {
                ErrorMessage = "Password change failed. Please verify your current password.";
                return;
            }

            SuccessMessage = "Password changed successfully.";
            await Task.Delay(500);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Password change failed: {ex.Message}";
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/");
    }

    private sealed class ChangePasswordModel
    {
        [Required]
        public string CurrentPassword { get; set; } = string.Empty;

        [Required]
        public string NewPassword { get; set; } = string.Empty;

        [Required]
        [Compare(nameof(NewPassword), ErrorMessage = "Passwords do not match")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
